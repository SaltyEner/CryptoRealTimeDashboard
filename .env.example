# =============================================================================
# .env.example — copia questo file in ".env" e riempi i valori.
# Il file ".env" NON va committato (è nel .gitignore).
# Per ora non serve nulla, ma prepariamo i campi per i passi futuri.
# =============================================================================

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=crypto-prices

# --- Sorgente dati (Binance, API pubblica, nessuna key necessaria) ---
# Simboli da seguire, separati da virgola (verranno usati dal Passo 2)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
POLL_INTERVAL_SECONDS=2

# --- PostgreSQL (Passo 3) ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline
POSTGRES_DB=crypto
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- AWS S3 (Passo 5) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=
